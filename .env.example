# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Comma-separated list of allowed CORS origins (dev + your Railway domain)
ALLOWED_ORIGINS=http://localhost:5173,https://YOUR-APP.up.railway.app

# Port (Railway sets this automatically; only needed for local docker run)
PORT=8000
